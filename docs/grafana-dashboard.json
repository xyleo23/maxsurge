{
  "title": "MaxSurge Production",
  "uid": "maxsurge-prod",
  "tags": ["maxsurge"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Users total",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "maxsurge_users_total", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "title": "Users active",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "maxsurge_users_active" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3, "type": "stat", "title": "Lifetime revenue (₽)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "maxsurge_revenue_rub_total" }],
      "fieldConfig": { "defaults": { "unit": "currencyRUB", "decimals": 0 } }
    },
    {
      "id": 4, "type": "stat", "title": "MAX accounts (active)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "maxsurge_accounts_active" }]
    },
    {
      "id": 5, "type": "stat", "title": "MAX accounts (blocked)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "maxsurge_accounts_blocked" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6, "type": "stat", "title": "Pending payments",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "maxsurge_payments_pending" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 7, "type": "timeseries", "title": "Users by plan",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "maxsurge_users_by_plan", "legendFormat": "{{plan}}" }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Revenue growth (₽)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "maxsurge_revenue_rub_total", "legendFormat": "Total ₽" }],
      "fieldConfig": { "defaults": { "unit": "currencyRUB" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "Messages sent (rate/min)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(maxsurge_messages_sent_total[5m]) * 60", "legendFormat": "msgs/min" }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Process memory (MB)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [{ "expr": "maxsurge_process_rss_bytes / 1024 / 1024", "legendFormat": "RSS MB" }],
      "fieldConfig": { "defaults": { "unit": "mbytes" } }
    },
    {
      "id": 11, "type": "stat", "title": "Tasks running",
      "gridPos": { "x": 0, "y": 18, "w": 6, "h": 4 },
      "targets": [{ "expr": "maxsurge_tasks_running" }]
    },
    {
      "id": 12, "type": "stat", "title": "Leads total",
      "gridPos": { "x": 6, "y": 18, "w": 6, "h": 4 },
      "targets": [{ "expr": "maxsurge_leads_total" }]
    },
    {
      "id": 13, "type": "stat", "title": "Last scrape age (sec)",
      "gridPos": { "x": 12, "y": 18, "w": 6, "h": 4 },
      "targets": [{ "expr": "time() - maxsurge_scrape_timestamp_seconds" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      }
    },
    {
      "id": 14, "type": "stat", "title": "Messages sent (lifetime)",
      "gridPos": { "x": 18, "y": 18, "w": 6, "h": 4 },
      "targets": [{ "expr": "maxsurge_messages_sent_total" }]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
