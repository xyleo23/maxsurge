# ──────────────────────────────────────────────────────────────
#  MaxSurge — шаблон переменных окружения
#  Скопируйте в .env и заполните реальными значениями
# ──────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///max_leadfinder.db
WEB_HOST=0.0.0.0
WEB_PORT=8090
SECRET_KEY=                              # openssl rand -hex 32

# ── Admin (auto-created on first startup) ───────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                          # ≥ 20 симв, генератор паролей

# ── Parser (2GIS) ───────────────────────────────────────────
DGIS_CITIES=Москва,Санкт-Петербург
DGIS_QUERIES=салон красоты,автосервис
DGIS_MAX_PAGES=3
SCRAPER_PROXY=                           # опционально

# ── Sender limits ───────────────────────────────────────────
SEND_DELAY_SEC=30
SEND_MAX_PER_ACCOUNT_DAY=50

# ── AI (OpenAI-compatible) ──────────────────────────────────
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ── SMTP (транзакционные письма) ────────────────────────────
# Yandex 360: smtp.yandex.ru / 465 / ваш@yandex.ru / пароль приложения
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@maxsurge.ru
SMTP_FROM_NAME=MaxSurge
SMTP_DRY_RUN=0                           # 1 = не отправлять, только лог

# ── Telegram алерты владельцу (ошибки + новые платежи) ──────
OWNER_TG_BOT_TOKEN=                      # @BotFather → /newbot
OWNER_TG_CHAT_ID=                        # ваш chat_id

# ── MAX (прокси для user-ботов) ─────────────────────────────
MAX_PROXY_URL=                           # http://user:pass@host:port, опционально

# ── Платежи: ЮKassa ─────────────────────────────────────────
YK_SHOP_ID=
YK_SECRET_KEY=
YK_RETURN_URL=https://maxsurge.ru/app/billing/success

# ── Платежи: Robokassa ──────────────────────────────────────
RB_MERCHANT_LOGIN=
RB_PASSWORD_1=                           # для создания платежа
RB_PASSWORD_2=                           # для проверки webhook
RB_IS_TEST=1                             # 1 = тест, 0 = продакшн

# ── Платежи: Prodamus ───────────────────────────────────────
PD_SHOP=                                 # субдомен: <shop>.payform.ru
PD_SECRET_KEY=                           # HMAC-SHA256 секрет из ЛК
PD_IS_TEST=1                             # 1 = demo_mode, 0 = продакшн

# Какие шлюзы показывать на странице оплаты
# yookassa | robokassa | prodamus | all
PAYMENT_GATEWAY=all
